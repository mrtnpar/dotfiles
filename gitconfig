[color]
	ui = auto
[alias]
	m = mergetool
	co = checkout
	d = difftool
[rerere]
	enabled = true
[pull]
	rebase = true
[fetch]
	prune = true
[core]
 	excludesfile = ~/.gitignore_global
 	autocrlf = input
	editor = code --wait
[push]
	autoSetupRemote = true
[user]
	name = Your Name
	email = your-email@example.com
[url "git@github.com:"]
	insteadOf = https://github.com/
[git-town]
	sync-feature-strategy = rebase
