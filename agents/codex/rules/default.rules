prefix_rule(pattern=["git", "add"], decision="allow")
prefix_rule(pattern=["git", "commit"], decision="allow")
prefix_rule(pattern=["tuist", "test"], decision="allow")
prefix_rule(pattern=["tuist", "generate"], decision="allow")
prefix_rule(pattern=["npm", "run", "release:validate"], decision="allow")
prefix_rule(pattern=["npm", "run", "release:screenshots"], decision="allow")
prefix_rule(pattern=["npm", "run", "release:archive"], decision="allow")
prefix_rule(pattern=["npm", "run", "release:beta"], decision="allow")
prefix_rule(pattern=["zsh", "-lc", "source ~/.zshrc >/dev/null 2>&1; npm run release:screenshots"], decision="allow")
prefix_rule(pattern=["npm", "run", "release:screenshots:latest:dark"], decision="allow")
prefix_rule(pattern=["./Scripts/setup.sh"], decision="allow")
prefix_rule(pattern=["./Scripts/apply-clerk-patches.sh"], decision="allow")
prefix_rule(pattern=["npm", "run", "ios:build:dev"], decision="allow")
prefix_rule(pattern=["npm", "run", "ios:test:dev"], decision="allow")
